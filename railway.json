{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pip install -r requirements.txt"
  },
  "deploy": {
    "runtime": "V2",
    "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT",
    "numReplicas": 1,
    "sleepApplication": false
  }
}